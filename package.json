{
  "name": "kianer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "lint": "eslint .",
    "static:sync": "bun run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "bun run static:sync && cd android && ./gradlew assembleDebug && cd .."
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@element-plus/icons-vue": "^2.3.2",
    "@iconify/vue": "^5.0.1",
    "@ionic/vue": "^8.8.11",
    "@ionic/vue-router": "^8.8.11",
    "element-plus": "^2.14.2",
    "epubjs": "^0.3.93",
    "ionicons": "^8.0.13",
    "localforage": "^1.10.0",
    "pako": "^2.2.0",
    "pdfjs-dist": "^6.0.227",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "8.4.1",
    "@eslint/js": "^10.0.1",
    "@types/pako": "^2.0.4",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "cypress": "^15.17.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "less": "^4.6.6",
    "terser": "^5.48.0",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-element-plus": "^0.11.2",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "description": "Kianer Reader - 跨平台电子书阅读器 (EPUB/PDF/TXT)"
}
