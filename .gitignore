# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*

# IDE
/.idea
/.vscode/*
!/.vscode/extensions.json

# Build output
/dist
/coverage
/node_modules
/www

# Capacitor Android — ignore build artifacts but keep project config
/android/app/build/
/android/.gradle/
/android/captures/
/android/local.properties

# Capacitor iOS
/ios/App/build/
/ios/App/App/public/
/ios/.build/

# Env
.env
.env.local
.env.production
